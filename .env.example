# ───────────────────────────────────────────────────────────────
# Honeybee — environment variables
# Copy to `.env` and fill in. Anything left blank falls back to mocks.
# ───────────────────────────────────────────────────────────────

# Runtime
DRY_RUN=true                       # set false ONLY to send real orders
LOOP_INTERVAL_SEC=60
LOG_LEVEL=INFO
BANKROLL_USD=1000

# Risk
KELLY_FRACTION=0.25
MAX_FRACTION_PER_MARKET=0.05
MAX_EXPOSURE_PER_MARKET_USD=25
DAILY_LOSS_LIMIT_USD=100
CONFIDENCE_FLOOR=0.55
MAX_USD_PER_LOOP=0.50              # LLM spend cap per orchestrator tick

# LLMs (any subset — router falls back to mock if all missing)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
LLM_CHEAP_MODEL=gpt-4o-mini
LLM_STRONG_MODEL=claude-sonnet-4-5

# Venues
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_EMAIL=
KALSHI_PASSWORD=
GEMINI_API_URL=https://api.gemini.com
GEMINI_API_KEY=
GEMINI_API_SECRET=

# ───────────── Web3 stack: Privy (wallet) + Arc (settlement) + ENS (identity) + x402 (pay-per-call)
WALLET_SERVICE_URL=http://127.0.0.1:8787
WALLET_PORT=8787

# Privy — embedded server-managed wallet (key never leaves Privy TEE)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=                   # set after first /wallet/create call; pinned for the agent

# Arc — primary settlement chain for agent economy
ARC_RPC_URL=https://rpc.arc.network        # update with the actual Arc RPC
ARC_CHAIN_ID=42161                          # placeholder; replace with Arc's chainId
ARC_EXPLORER_URL=https://explorer.arc.network

# ENS — agent reputation / handle. Subnames issued under a parent the agent controls.
ENS_PARENT=honeybee.agent.eth      # parent domain you own (or testnet equivalent)
ENS_AGENT_LABEL=alpha-trader       # this agent's subname; full = alpha-trader.honeybee.agent.eth
ENS_MAINNET_RPC=https://eth.llamarpc.com   # for ENS reads (ENS lives on Ethereum mainnet)

# x402 — HTTP 402 micropayments. Used by Data Agent for paid APIs & inter-agent payments.
X402_FACILITATOR_URL=https://x402.org/facilitator   # facilitator that settles on Arc
X402_PAY_TOKEN=USDC                # asset used to settle x402 invoices on Arc
X402_MAX_PAYMENT_USD=0.10          # hard cap per single 402 settlement
X402_DAILY_BUDGET_USD=5.00         # daily ceiling on x402 spend

# State
LEDGER_PATH=./var/honeybee.db
