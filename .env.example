# ── Honeybee .env.example ──────────────────────────────────────────────────
# Copy to .env and fill in. All blanks fall back to mocks / paper mode.

# LLM (Anthropic only — required for real analysis; mock used if absent)
ANTHROPIC_API_KEY=

# Polymarket (read-only endpoints are public; private key only for --live)
POLYMARKET_PRIVATE_KEY=      # live trading only — funded Polygon key (mainnet, real money)
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
# Optional live-execution tuning (defaults shown):
POLYMARKET_SIGNATURE_TYPE=0  # 0=EOA, 1=Magic/email proxy, 2=browser proxy
POLYMARKET_FUNDER=           # defaults to signer address; set to proxy addr for type 1/2
# Pre-derived L2 API creds (optional) — if all three are set, LiveWallet uses
# them directly and skips deriving from the key on startup. Leave blank to derive.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# NOTE: EOA wallets need one-time USDC + CTF allowances to the exchange contracts
# before fills settle. Polymarket is mainnet-only (no testnet).
# Kalshi: market + orderbook reads are PUBLIC (no creds needed for discovery).
# For order submission, the TS wallet service signs requests with an RSA API key.
# Use the DEMO sandbox for safe fills: https://external-api.demo.kalshi.co/trade-api/v2
KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
GEMINI_API_URL=https://api.gemini.com
GEMINI_API_KEY=
GEMINI_API_SECRET=

# Optional data sources
SEARCH_API_KEY=              # Brave/Serper search API for Data Agent

# Storage (SQLite by default; swap DATABASE_URL for Postgres later)
DATABASE_URL=                # unused for now; SqliteRepository is the default

# Privy — embedded server-managed wallet (key never leaves Privy TEE)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_WALLET_ID=                   # set after first /wallet/create call; pinned for the agent

# Authorization-key + policy rails for the agent fleet (filled by `make bootstrap-privy`).
# The auth key signs every wallet mutation; the policy locks wallets to Arc
# and caps per-tx value. The app secret alone CAN'T move funds.
PRIVY_AUTH_PRIVATE_KEY=            # base64 PKCS#8 P-256 private key
PRIVY_AUTH_PUBLIC_KEY=             # base64 SPKI P-256 public key
PRIVY_OWNER_KEY_QUORUM_ID=         # owner attached to each agent wallet
PRIVY_POLICY_ID=                   # chain-locked policy id

# Arc — primary settlement chain for agent economy
ARC_RPC_URL=https://rpc.arc.network        # update with the actual Arc RPC
ARC_CHAIN_ID=42161                          # placeholder; replace with Arc's chainId
ARC_EXPLORER_URL=https://explorer.arc.network

# Honeybee on-chain identity + reputation contracts (set after `make contracts-deploy`)
AGENT_IDENTITY_ADDRESS=
ATTESTATION_REGISTRY_ADDRESS=
DEPLOYER_PRIVATE_KEY=                       # hex (with or without 0x); deploys + signs attestations

# Optional demo agent provisioned by Deploy.s.sol
DEMO_AGENT_LABEL=alpha-trader               # leftmost label under ENS_PARENT
DEMO_AGENT_OWNER=                           # defaults to deployer if blank
DEMO_AGENT_ROLE=research
DEMO_AGENT_MODEL=claude-sonnet-4-5
DEMO_AGENT_DESC=Long-tail prediction market research

# ENS-shaped identity — we mirror ENS semantics on Arc via AgentIdentity.sol.
# Real ENS (mainnet) is still used for off-chain display + reputation portability.
ENS_PARENT=honeybee.agent          # parent domain for AgentIdentity (no .eth on Arc)
ENS_AGENT_LABEL=alpha-trader       # this agent's leftmost label; full node = label.parent
ENS_MAINNET_RPC=https://eth.llamarpc.com   # optional: for mainnet ENS reads

# x402 — HTTP 402 micropayments. Used by Data Agent for paid APIs & inter-agent payments.
X402_FACILITATOR_URL=https://x402.org/facilitator   # facilitator that settles on Arc
X402_PAY_TOKEN=USDC                # asset used to settle x402 invoices on Arc
X402_MAX_PAYMENT_USD=0.10          # hard cap per single 402 settlement
X402_DAILY_BUDGET_USD=5.00         # daily ceiling on x402 spend

# State
LEDGER_PATH=./var/honeybee.db

# Runtime
DRY_RUN=true                 # set false ONLY with --live flag
LOG_LEVEL=INFO

# Storage backend: sqlite (default) | supabase
REPO_BACKEND=sqlite
SUPABASE_URL=                # https://<ref>.supabase.co
SUPABASE_ANON_KEY=           # publishable/anon key — safe for frontend
SUPABASE_SERVICE_ROLE_KEY=   # service_role key — server-side ONLY, never ship to browser
# SUPABASE_DB_URL=postgresql://postgres:[PASSWORD]@db.<ref>.supabase.co:5432/postgres
